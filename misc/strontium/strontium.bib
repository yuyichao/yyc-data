@article{stellmerProductionPhys.Rev.A2013,
  title = {Production of Quantum-Degenerate Strontium Gases},
  author = {Stellmer, Simon and Grimm, Rudolf and Schreck, Florian},
  year = 2013,
  month = jan,
  journal = {Phys. Rev. A},
  volume = {87},
  number = {1},
  pages = {013611},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevA.87.013611},
  urldate = {2024-12-12},
  abstract = {We report on an improved scheme to generate Bose-Einstein condensates (BECs) and degenerate Fermi gases of strontium. This scheme allows us to create quantum gases with higher atom number, a shorter time of the experimental cycle, or deeper quantum degeneracy than before. We create a BEC of 84Sr exceeding 107 atoms, which is a 30-fold improvement over previously reported experiments. We increase the atom number of 86Sr BECs to 2.5\texttimes 104 (a fivefold improvement) and refine the generation of attractively interacting 88Sr BECs. We present a scheme to generate 84Sr BECs with a cycle time of 2 s. We create deeply degenerate 87Sr Fermi gases with {$T$}/{$TF$} as low as 0.10(1), where the number of populated nuclear spin states can be set to any value between one and ten. Furthermore, we report on a total of five different double-degenerate Bose-Bose and Bose-Fermi mixtures. These studies prepare an excellent starting point for applications of strontium quantum gases anticipated in the near future.},
  keywords = {Bose-Einstein condensate (BEC),Laser Cooling,Laser Cooling and Trapping,Strontium (Sr)}
}

@misc{tangDetermination2025,
  title = {Determination of Nuclear Quadrupole Moments for \$\textasciicircum\textbraceleft 25\textbraceright\${{Mg}}, \$\textasciicircum\textbraceleft 87\textbraceright\${{Sr}}, and \$\textasciicircum\textbraceleft 135,137\textbraceright\${{Ba}} via Configuration-Interaction Combined with a Coupled-Cluster Approach},
  author = {Tang, Yong-Bo},
  year = 2025,
  publisher = {arXiv},
  doi = {10.48550/ARXIV.2512.07603},
  urldate = {2026-02-13},
  abstract = {Using the configuration-interaction plus coupled-cluster approach, we calculate the electric-field gradients \$q\$ for the low-lying states of alkaline-earth atoms, including magnesium (Mg), strontium (Sr), and barium (Ba). These low-lying states specifically include the \$3s3p\textasciitilde\textasciicircum 3\textbackslash!P\_\textbraceleft 1,2\textbraceright\$ states of Mg; the \$5s4d\textasciitilde\textasciicircum 1\textbackslash!D\_\textbraceleft 2\textbraceright\$ and \$5s5p\textasciitilde\textasciicircum 3\textbackslash!P\_\textbraceleft 1,2\textbraceright\$ states of Sr; as well as the \$6s5d\textasciitilde\textasciicircum 3\textbackslash!D\_\textbraceleft 1,2,3\textbraceright\$, \$6s5d\textasciitilde\textasciicircum 1\textbackslash!D\_\textbraceleft 2\textbraceright\$, and \$6s6p\textasciitilde\textasciicircum 1\textbackslash!P\_\textbraceleft 1\textbraceright\$ states of Ba. By combining the measured electric quadrupole hyperfine-structure constants of these states, we accurately determine the nuclear quadrupole moments of \$\textasciicircum\textbraceleft 25\textbraceright\$Mg, \$\textasciicircum\textbraceleft 87\textbraceright\$Sr, and \$\textasciicircum\textbraceleft 135,137\textbraceright\$Ba. These results are compared with the available data. The comparison shows that our nuclear quadrupole moment of \$\textasciicircum\textbraceleft 25\textbraceright\$Mg is in perfect agreement with the result from the mesonic X-ray experiment. However, there are approximately 10\textbackslash\% and 4\textbackslash\% differences between our results and the currently adopted values [Pyykk\$\textbackslash rm \textbackslash ddot\textbraceleft o\textbraceright\$, Mol. Phys. 116, 1328(2018)] for the nuclear quadrupole moments of \$\textasciicircum\textbraceleft 87\textbraceright\$Sr and \$\textasciicircum\textbraceleft 135,137\textbraceright\$Ba respectively. Moreover, we also calculate the magnetic dipole hyperfine-structure constants of these states, and the calculated results exhibit good agreement with the measured data.},
  copyright = {Creative Commons Attribution 4.0 International},
  langid = {english},
  keywords = {Barium (Ba),Hyperfine Structure,Magnesium (Mg),Metastable State,Strontium (Sr)}
}

@article{vaillantLongrangeJ.Phys.B:At.Mol.Opt.Phys.2012,
  title = {Long-Range {{Rydberg}}--{{Rydberg}} Interactions in Calcium, Strontium and Ytterbium},
  author = {Vaillant, C. L. and Jones, M. P. A. and Potvliege, R. M.},
  year = 2012,
  month = jun,
  journal = {J. Phys. B: At. Mol. Opt. Phys.},
  volume = {45},
  number = {13},
  pages = {135004},
  publisher = {IOP Publishing},
  issn = {0953-4075},
  doi = {10.1088/0953-4075/45/13/135004},
  urldate = {2024-12-01},
  abstract = {Long-range dipole--dipole and quadrupole--quadrupole interactions between pairs of Rydberg atoms are calculated perturbatively for calcium, strontium and ytterbium within the Coulomb approximation. Quantum defects, obtained by fitting existing laser spectroscopic data, are provided for all S, P, D and F series of strontium and for the 3P2 series of calcium. The results show qualitative differences with the alkali metal atoms, including isotropically attractive interactions of the strontium 1S0 states and a greater rarity of F\"orster resonances. Only two such resonances are identified, both in triplet series of strontium. The angular dependence of the long-range interaction is briefly discussed.},
  langid = {english},
  keywords = {Calcium (Ca),Rydberg,Rydberg Atom,Strontium (Sr),Theory,Ultracold Atoms,Ytterbium (Yb)}
}

@article{zelevinskyOpticalHyperfineInteract2007,
  title = {Optical Clock and Ultracold Collisions with Trapped Strontium Atoms},
  author = {Zelevinsky, T. and Boyd, M. M. and Ludlow, A. D. and Foreman, S. M. and Blatt, S. and Ido, T. and Ye, J.},
  year = 2007,
  month = jan,
  journal = {Hyperfine Interact},
  volume = {174},
  number = {1},
  pages = {55--64},
  issn = {1572-9540},
  doi = {10.1007/s10751-007-9564-x},
  urldate = {2026-02-12},
  abstract = {With microkelvin neutral strontium atoms confined in an optical lattice, we have achieved a fractional resolution of better than 5\texttimes 10--15 on the 1S0--3P0 doubly forbidden 87Sr clock transition at 698 nm. Measurements of the clock line shifts as a function of experimental parameters indicate that the fractional uncertainties due to systematic shifts could be reduced below 10--15. The ultrahigh spectral resolution permitted resolving the nuclear spin states of the clock transition at small magnetic fields, leading to measurements of the 3P0 magnetic moment and metastable lifetime. In addition, photoassociation spectroscopy was performed on the narrow 1S0--3P1 transition of 88Sr, revealing the least-bound state, and showing promise for efficient optical tuning of the ground state scattering length and production of cold molecules.},
  langid = {english},
  keywords = {Optical Clock,Strontium (Sr)}
}

@article{zhouMagicPhys.Rev.A2010,
  title = {Magic Wavelengths for Terahertz Clock Transitions},
  author = {Zhou, Xiaoji and Xu, Xia and Chen, Xuzong and Chen, Jingbiao},
  year = 2010,
  month = jan,
  journal = {Phys. Rev. A},
  volume = {81},
  number = {1},
  pages = {012115},
  publisher = {American Physical Society},
  doi = {10.1103/PhysRevA.81.012115},
  urldate = {2024-12-11},
  abstract = {Magic wavelengths for laser trapping of boson isotopes of alkaline-earth metal atoms Sr, Ca, and Mg are investigated while considering terahertz clock transitions between the 3⁢{$P$}0, 3⁢{$P$}1, and 3⁢{$P$}2 metastable triplet states. Our calculation shows that magic wavelengths for laser trapping do exist. This result is important because those metastable states have already been used to make accurate clocks in the terahertz frequency domain. Detailed discussions for magic wavelengths for terahertz clock transitions are given in this article.},
  keywords = {Calcium (Ca),Light Shifts,Magic Wavelength,Magnesium (Mg),Polarizability,Strontium (Sr)}
}
